# Notion Integration Token
# Get from: notion.so → Settings → Connections → Develop or manage integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Articles Database ID
# Get from the database URL: notion.so/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# imgbb API Key (free)
# Get from: imgbb.com → Account → API
IMGBB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Unsplash Access Key (optional — used for cover images)
# Get from: unsplash.com/developers → Your apps → Access Key
UNSPLASH_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
